---
// Commission/Contact section for VM MOBILE
---
<section class="commission" id="commission" data-section="04 / Kontakt">
  <div class="grid">
    <h2 class="commission-title display">Pokrenite posao<br />bez zastoja.</h2>
    <div class="commission-steps" aria-label="Proces saradnje">
      <div class="step"><b>01</b><span>Kontakt / lokacija / potrebe</span></div>
      <div class="step"><b>02</b><span>Ponuda kase + materijala</span></div>
      <div class="step"><b>03</b><span>Fiskalizacija + unos artikala</span></div>
      <div class="step"><b>04</b><span>Terenska isporuka + obuka</span></div>
    </div>
    <div class="direct-wrap">
      <div class="direct">
        Kontakt servisa<br />
        Mirko Vranić (serviser)<br />
        <a href="mailto:vm.mobile.vranic@gmail.com">vm.mobile.vranic@gmail.com</a><br />
        <a href="tel:+381637495456">063 7 495 456</a><br />
        Srpskih vladara 210, Petrovac<br />
        Terenska podrška: Petrovac, Požarevac, Kučevo, Despotovac, Velika Plana, Svilajnac, Majdanpek, Golubac, Malo Crniće<br />
        <a href="#fb">Facebook</a> / <a href="#ig">Instagram</a>
      </div>
      <div class="map-wrap">
        <iframe src="https://www.google.com/maps/embed?pb=!1m12!1m8!1m3!1d332.74439148095826!2d21.41621491028556!3d44.37856596445068!3m2!1i1024!2i768!4f13.1!2m1!1sSrpskih%20Vladara!5e1!3m2!1sen!2srs!4v1784301045645!5m2!1sen!2srs" width="100%" height="200" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin" title="Lokacija VM MOBILE Petrovac na Mlavi"></iframe>
      </div>
    </div>
    <div class="form-wrap">
      <form class="form-grid" id="commission-form">
        <div class="field">
          <label for="name">Ime i prezime / Naziv firme *</label>
          <input id="name" name="name" type="text" autocomplete="name" required />
        </div>
        <div class="field">
          <label for="email">Email adresa *</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
        </div>
        <div class="field">
          <label for="location">Lokacija (Mesto / Opština) *</label>
          <input id="location" name="location" type="text" autocomplete="address-level2" placeholder="NPR. PETROVAC, POŽAREVAC, KUČEVO..." required />
        </div>
        <div class="field">
          <label for="type">Vrsta usluge *</label>
          <select id="type" name="type" required>
            <option value="">Izaberite</option>
            <option>Servis kase</option>
            <option>Kupovina nove kase</option>
            <option>Kancelarijski materijal</option>
            <option>Stručne konsultacije</option>
          </select>
        </div>
        <div class="field">
          <label for="dimensions">Obim posla</label>
          <input id="dimensions" name="dimensions" type="text" placeholder="NPR. BROJ ARTIKALA, KOLIČINA ROLNI" />
        </div>
        <div class="field">
          <label for="timeframe">Rok za realizaciju</label>
          <input id="timeframe" name="timeframe" type="text" placeholder="NPR. HITNO, OVE NEDELJE, MESEC" />
        </div>
        <div class="field full">
          <label for="brief">Opis zahteva *</label>
          <textarea id="brief" name="brief" required placeholder="DETALJI O KVARU KASE, MODELU ILI SPISAK MATERIJALA"></textarea>
        </div>
        <button class="submit" type="submit">
          <span>Pošaljite zahtev servisu</span>
          <span>↗</span>
        </button>
        <p class="form-status" id="form-status" aria-live="polite"></p>
      </form>
    </div>
  </div>
  <footer class="footer">
    <div class="footer-mark">
      <img src="/logo.svg" alt="VM MOBILE Logo" class="footer-logo" />
    </div>
    <div>Prodaja i servis fiskalnih kasa<br />Petrovac, Požarevac i okolne opštine</div>
    <div>© 2026<br />Privatnost / pravne napomene</div>
  </footer>
</section>
